{
  "name": "hanzi-graded-reader",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "data:download": "tsx data/pipeline/download.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "data:build": "tsx data/pipeline/build.ts",
    "data:verify": "tsx data/pipeline/verify.ts",
    "data:all": "pnpm data:download && pnpm data:build && pnpm data:verify",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:integration": "vitest run cli",
    "typecheck": "tsc -p tsconfig.node.json",
    "story": "tsx --env-file=.env cli/story.ts",
    "eval": "tsx --env-file=.env evals/runner.ts",
    "eval:judge": "tsx --env-file=.env evals/judge.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@base-ui/react": "^1.6.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.4",
    "hanzi-writer": "^3.7.3",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.30.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
