# Generation engine (Phase 3) — required only for the real-LLM eval harness.
# Unit tests use MockLlmProvider and need none of these.
ANTHROPIC_API_KEY=

# OpenRouter (alternative provider — one OpenAI-compatible API over many models).
# Required only when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# Optional overrides. Default provider is anthropic, default model claude-haiku-4-5.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5
#
# For OpenRouter, use slug model ids (vendor/model), NOT the Anthropic-native form.
# The repair loop caches the system+vocab prefix on anthropic/* and google/* models.
# Pass slugs to `pnpm story --model` / eval profiles too when on OpenRouter.
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-haiku-4.5
#
# OpenRouter Presets: drive model/routing/params from a server-side preset (change the model
# from the OpenRouter dashboard with no code edit) by setting LLM_MODEL to its slug:
# LLM_MODEL=@preset/your-slug
#
# Prompt caching for a bare @preset/slug can't be auto-detected (we don't know the resolved
# model), so it's off by default. Set LLM_CACHE=on to force caching when your preset routes to
# an Anthropic/Gemini model. auto (default) infers from a vendor-prefixed LLM_MODEL; off disables.
# LLM_CACHE=auto

# Judge (`pnpm eval:judge` and `pnpm story --judge`) is a SEPARATE setup — its own provider +
# model, so you can write with a cheap model and judge with a stronger one (even a different
# provider). LLM_JUDGE_PROVIDER falls back to LLM_PROVIDER when unset; default model is
# claude-sonnet-4-6. On OpenRouter, use a slug (e.g. anthropic/claude-sonnet-4.5).
# LLM_JUDGE_PROVIDER=anthropic
# LLM_JUDGE_MODEL=claude-sonnet-4-6

# Auth (required to run the web app). See docs/ADMIN_GUIDE.md §9.
AUTH_SECRET=            # generate with: npx auth secret
AUTH_GOOGLE_ID=         # Google OAuth client id (adult sign-in)
AUTH_GOOGLE_SECRET=     # Google OAuth client secret
# AUTH_URL=http://localhost:3000   # public origin; set in production

# DB location. Defaults to ./data/hanzi.db locally; point at the mounted volume in prod.
# DB_PATH=/data/hanzi.db
