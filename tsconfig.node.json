{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": { "@/*": ["./*"] }
  },
  "include": ["db", "data", "lib", "evals", "cli", "drizzle.config.ts", "vitest.config.ts"]
}
